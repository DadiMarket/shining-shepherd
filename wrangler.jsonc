{
	"compatibility_date": "2026-02-24",
	"compatibility_flags": ["global_fetch_strictly_public", "nodejs_compat", ],
	"name": "shining-shepherd",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	}
}